#!/usr/bin/env bash
set -euo pipefail

DOTFILES_BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=common.sh
source "$DOTFILES_BIN_DIR/common.sh"
# shellcheck source=linux.sh
source "$DOTFILES_BIN_DIR/linux.sh"

bootstrap_packages() {
  if [[ "$DOTFILES_TARGET" == "darwin" ]]; then
    if ! xcode-select -p >/dev/null 2>&1; then
      xcode-select --install
      echo "Install Command Line Tools, then re-run ./bin/bootstrap"
      exit 1
    fi

    if ! command -v brew >/dev/null 2>&1; then
      /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    fi

    eval "$(/opt/homebrew/bin/brew shellenv || /usr/local/bin/brew shellenv)"
    brew bundle --file="$DOTFILES_ROOT/Brewfile"
  else
    echo "Skipping Homebrew package bootstrap for linux."
  fi
}

link() {
  local src="$1"
  local target="$2"

  mkdir -p "$(dirname "$target")"
  if [[ -d "$target" && ! -L "$target" ]]; then
    rm -rf "$target"
  fi
  ln -sfn "$src" "$target"
}

resolve_target
set_platform_paths
bootstrap_packages
bootstrap_linux_tools

HOME_CONFIG_ROOT="$DOTFILES_ROOT/home/.config"
APP_CONFIG_ROOT="$DOTFILES_ROOT/app-config"

for f in .zshrc .zprofile .zshenv .p10k.zsh .gitconfig; do
  link "$DOTFILES_ROOT/home/$f" "$HOME/$f"
done
link "$DOTFILES_ROOT/home/.zsh/functions" "$HOME/.zsh/functions"
link "$DOTFILES_ROOT/home/.zsh/keybindings.zsh" "$HOME/.zsh/keybindings.zsh"

link "$DOTFILES_ROOT/home/.claude/settings.json" "$HOME/.claude/settings.json"
link "$DOTFILES_ROOT/home/.claude/statusline-command.sh" "$HOME/.claude/statusline-command.sh"

link "$HOME_CONFIG_ROOT/nvim" "$HOME/.config/nvim"
link "$HOME_CONFIG_ROOT/mc" "$HOME/.config/mc"
link "$HOME_CONFIG_ROOT/gh/config.yml" "$HOME/.config/gh/config.yml"
link "$HOME_CONFIG_ROOT/htop/htoprc" "$HOME/.config/htop/htoprc"
link "$HOME_CONFIG_ROOT/git/ignore" "$HOME/.config/git/ignore"
link "$HOME_CONFIG_ROOT/zed/settings.json" "$HOME/.config/zed/settings.json"

link "$APP_CONFIG_ROOT/ghostty/config" "$DOTFILES_GHOSTTY_CONFIG_PATH"
link "$APP_CONFIG_ROOT/vscode-insiders/User/settings.json" "$DOTFILES_VSCODE_USER_DIR/settings.json"

if [[ -f "$APP_CONFIG_ROOT/vscode-insiders/User/keybindings.json" ]]; then
  link "$APP_CONFIG_ROOT/vscode-insiders/User/keybindings.json" "$DOTFILES_VSCODE_USER_DIR/keybindings.json"
fi

if [[ -d "$APP_CONFIG_ROOT/vscode-insiders/User/snippets" ]]; then
  link "$APP_CONFIG_ROOT/vscode-insiders/User/snippets" "$DOTFILES_VSCODE_USER_DIR/snippets"
fi

ln -sfn "$HOME/.config/git/ignore" "$HOME/.gitignore"

if [[ ! -f "$HOME/.zsh_secrets" ]]; then
  echo "Create $HOME/.zsh_secrets manually (not in git)."
fi
