#!/usr/bin/env bash
set -euo pipefail

DOTFILES_BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=common.sh
source "$DOTFILES_BIN_DIR/common.sh"

BACKUP="$HOME/.dotfiles-backup-$(date +%Y%m%d-%H%M%S)"
mkdir -p "$HOME/.config"

backup_item() {
  local target="$1"
  if [ -e "$target" ] || [ -L "$target" ]; then
    mkdir -p "$BACKUP"
    local rel="${target#$HOME/}"
    local backup_target="$BACKUP/$rel"
    mkdir -p "$(dirname "$backup_target")"
    mv "$target" "$backup_target"
  fi
}

link_item() {
  local src="$1"
  local target="$2"
  mkdir -p "$(dirname "$target")"
  ln -sfn "$src" "$target"
}

link_with_backup() {
  local src="$1"
  local target="$2"

  if [ -L "$target" ] && [ "$(readlink "$target")" = "$src" ]; then
    return
  fi

  backup_item "$target"
  link_item "$src" "$target"
}

resolve_target
set_platform_paths

for f in .zshrc .zprofile .zshenv .p10k.zsh .gitconfig; do
  link_with_backup "$DOTFILES_ROOT/home/$f" "$HOME/$f"
done

link_with_backup "$DOTFILES_ROOT/home/.zsh/functions" "$HOME/.zsh/functions"
link_with_backup "$DOTFILES_ROOT/home/.zsh/keybindings.zsh" "$HOME/.zsh/keybindings.zsh"

link_with_backup "$DOTFILES_ROOT/config/nvim" "$HOME/.config/nvim"
link_with_backup "$DOTFILES_ROOT/config/mc" "$HOME/.config/mc"
link_with_backup "$DOTFILES_ROOT/config/htop/htoprc" "$HOME/.config/htop/htoprc"
link_with_backup "$DOTFILES_ROOT/config/git/ignore" "$HOME/.config/git/ignore"
link_with_backup "$HOME/.config/git/ignore" "$HOME/.gitignore"

link_with_backup "$DOTFILES_ROOT/config/ghostty/config" "$DOTFILES_GHOSTTY_CONFIG_PATH"
link_with_backup "$DOTFILES_ROOT/config/vscode-insiders/User/settings.json" "$DOTFILES_VSCODE_USER_DIR/settings.json"

if [ -f "$DOTFILES_ROOT/config/vscode-insiders/User/keybindings.json" ]; then
  link_with_backup "$DOTFILES_ROOT/config/vscode-insiders/User/keybindings.json" "$DOTFILES_VSCODE_USER_DIR/keybindings.json"
fi

if [ -d "$DOTFILES_ROOT/config/vscode-insiders/User/snippets" ]; then
  link_with_backup "$DOTFILES_ROOT/config/vscode-insiders/User/snippets" "$DOTFILES_VSCODE_USER_DIR/snippets"
fi
