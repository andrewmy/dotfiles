{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio",
      "options": {
        "baseURL": "http://192.168.50.224:1234/v1"
      },
      "models": {
        "qwen/qwen3.6-35b-a3b": {
          "name": "Qwen 3.6 35B"
        }
      }
    }
  },
  "mcp": {
    "gitnexus": {
      "type": "local",
      "command": [
        "mcp-compressor",
        "--compression-level",
        "high",
        "--toonify",
        "{\"mcpServers\":{\"gitnexus\":{\"command\":\"/opt/homebrew/bin/gitnexus\",\"args\":[\"mcp\"]}}}"
      ]
    },
    "context7": {
      "type": "local",
      "command": [
        "mcp-compressor",
        "--compression-level",
        "high",
        "--toonify",
        "{\"mcpServers\":{\"context7\":{\"command\":\"npx\",\"args\":[\"-y\",\"@upstash/context7-mcp\"]}}}"
      ]
    },
    "playwright": {
      "type": "local",
      "command": [
        "mcp-compressor",
        "--compression-level",
        "high",
        "--toonify",
        "{\"mcpServers\":{\"playwright\":{\"command\":\"npx\",\"args\":[\"@playwright/mcp@latest\"]}}}"
      ]
    },
    "serena": {
      "type": "local",
      "command": [
        "mcp-compressor",
        "--compression-level",
        "high",
        "--toonify",
        "{\"mcpServers\":{\"serena\":{\"command\":\"uvx\",\"args\":[\"--from\",\"git+https://github.com/oraios/serena\",\"serena\",\"start-mcp-server\"]}}}"
      ]
    },
    "wick": {
      "type": "local",
      "command": [
        "mcp-compressor",
        "--compression-level",
        "high",
        "--toonify",
        "{\"mcpServers\":{\"wick\":{\"command\":\"/opt/homebrew/bin/wick\",\"args\":[\"serve\",\"--mcp\"]}}}"
      ]
    }
  }
}
